{
  "name": "learning-tracker",
  "version": "1.0.0",
  "description": "MCP server for tracking tutorial progress and spaced repetition learning",
  "keywords": [
    "mcp",
    "claude-code",
    "tutorial",
    "curriculum",
    "spaced-repetition",
    "quiz",
    "mock-interview",
    "capstone"
  ],
  "license": "MIT",
  "author": "Joseph Crozet",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "learning-tracker": "dist/index.js"
  },
  "scripts": {
    "preinstall": "npx only-allow npm",
    "postinstall": "lefthook install",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/sql.js": "^1.4.11",
    "lefthook": "^2.1.10",
    "only-allow": "^1.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
