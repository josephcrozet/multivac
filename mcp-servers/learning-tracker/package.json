{
  "name": "learning-tracker",
  "version": "1.0.0",
  "description": "MCP server for tracking tutorial progress and spaced repetition learning",
  "keywords": [
    "mcp",
    "learning",
    "tutorial",
    "spaced-repetition"
  ],
  "license": "MIT",
  "author": "Joseph Crozet",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "learning-tracker": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts",
    "preinstall": "npx only-allow npm",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/sql.js": "^1.4.11",
    "lefthook": "^2.1.9",
    "only-allow": "^1.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
